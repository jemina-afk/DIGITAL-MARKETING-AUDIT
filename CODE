      "Every page of your website should offer a clear and easy way for a visitor to take action — a contact form, a booking link or an irresistible free offer that captures their email address in exchange for something valuable.",
      "The business that responds first almost always wins the inquiry. Studies consistently show that responding to a new lead within 5 minutes increases your chance of conversion by over 80%. This needs to happen automatically, not manually.",
      "Most customers need more than one touchpoint before they are ready to commit. A simple automated sequence of 2 to 3 follow-up messages sent over the days after an initial inquiry can dramatically increase your conversion rate without any additional effort on your part.",
      "Track where your inquiries are coming from every month — which platform, which page, which campaign. Without this data you are spending time and money based on guesswork rather than evidence."
    ],
    tulivo: "At Tulivo Digital we build complete marketing funnels for small businesses — from the website page that captures the lead to the automated follow-up sequence that converts them into a customer. We also set up instant lead response systems so that every inquiry receives a professional reply within minutes, whether you are available or not.",
    showTulivo: true
  }
};

const answers = {};
let totalAnswered = 0;
let userName = "";
let bizName = "";
let hasWebsite = true;

function startAudit() {
  const fn = document.getElementById("fname").value.trim();
  const bn = document.getElementById("bname").value.trim();
  const em = document.getElementById("email").value.trim();
  const err = document.getElementById("err1");
  const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(em);
  if (!fn || !bn || !em || !emailOk) { err.style.display = "block"; return; }
  err.style.display = "none";
  userName = fn;
  bizName = bn;
  buildAudit();
  document.getElementById("greeting").textContent = "Hi " + fn + " — answer yes or no to each question below";
  show("s2");
}

function buildAudit() {
  const wrap = document.getElementById("audit-wrap");
  wrap.innerHTML = "";
  SECTIONS.forEach((s, si) => {
    const card = document.createElement("div");
    card.className = "section-card";
    card.innerHTML = `<div class="sec-head" style="background:${s.color}">
      <div class="sec-icon">${s.icon}</div>
      <span class="sec-label" style="color:${s.tc}">${s.title}</span>
      <span class="sec-score" id="ss${si}" style="color:${s.tc}">0/5</span>
    </div>`;
    s.qs.forEach((q, qi) => {
      const key = `${si}-${qi}`;
      const row = document.createElement("div");
      row.className = "q-row";
      row.innerHTML = `<span class="q-text">${qi + 1 + si * 5}. ${q}</span>
        <div class="btn-group">
          <button class="btn-yn btn-yes" onclick="ans('${key}',true,this)">Yes</button>
          <button class="btn-yn btn-no" onclick="ans('${key}',false,this)">No</button>
        </div>`;
      card.appendChild(row);
    });
    wrap.appendChild(card);
  });
}

function ans(key, val, btn) {
  const already = key in answers;
  answers[key] = val;
  if (key === "0-0") hasWebsite = val;
  const btns = btn.parentNode.querySelectorAll(".btn-yn");
  btns[0].className = "btn-yn btn-yes" + (val === true ? " on" : "");
  btns[1].className = "btn-yn btn-no" + (val === false ? " on" : "");
  if (!already) totalAnswered++;
  document.getElementById("prog").style.width = (totalAnswered / 20 * 100) + "%";
  document.getElementById("prog-count").textContent = totalAnswered;
  const si = key.split("-")[0];
  let c = 0;
  for (let qi = 0; qi < 5; qi++) { if (answers[`${si}-${qi}`] === true) c++; }
  document.getElementById("ss" + si).textContent = c + "/5";
  if (totalAnswered === 20) setTimeout(showResults, 500);
}

function showResults() {
  const yeses = Object.values(answers).filter(v => v === true).length;
  const pct = Math.round(yeses / 20 * 100);
  document.getElementById("score-num").innerHTML = yeses + '<span class="score-denom">/20</span>';
  document.getElementById("res-name").textContent = userName + " — " + bizName;

  const tier = TIERS.find(t => yeses >= t.min);
  document.getElementById("score-fill").style.width = pct + "%";
  document.getElementById("score-fill").style.background = tier.color;
  document.getElementById("result-title").textContent = tier.label;
  document.getElementById("result-body").textContent = tier.text;
  const rb = document.getElementById("result-box");
  rb.style.background = tier.color + "15";
  rb.style.borderLeft = "4px solid " + tier.color;

  // No website message
  const nwMsg = document.getElementById("no-website-msg");
  if (!hasWebsite) {
    nwMsg.innerHTML = `<div class="no-website-box">
      <h3>You answered no to having a website</h3>
      <p>That is completely okay — many small businesses start without one. But a website is the single biggest thing you can do to make your business findable and credible online. It does not need to be expensive or complicated to be effective.</p>
      <p>At Tulivo Digital we build websites for small businesses from scratch. <a href="https://tulivo.digital" style="color:#9A3412;font-weight:600">Book a free consultation</a> and we will show you exactly what is possible for your business and your budget — no pressure, no jargon.</p>
    </div>`;
  } else {
    nwMsg.innerHTML = "";
  }

  // Focus areas
  const weakAreas = [];
  SECTIONS.forEach((s, si) => {
    let c = 0;
    for (let qi = 0; qi < 5; qi++) { if (answers[`${si}-${qi}`] === true) c++; }
    if (c <= 2) weakAreas.push({ title: s.title, score: c, icon: s.icon, si });
  });

  const fa = document.getElementById("focus-areas");
  if (weakAreas.length) {
    fa.innerHTML = `<p class="focus-title">Your focus areas</p>` +
      weakAreas.map(w => `<div class="focus-row">
        <span style="font-size:16px">${w.icon}</span>
        <span class="focus-name">${w.title}</span>
        <span class="focus-score">${w.score}/5 yes</span>
      </div>`).join("") +
      `<p style="font-size:12px;color:#9CA3AF;margin-top:6px;margin-bottom:4px">Personalised advice for each area is below.</p>`;
  } else {
    fa.innerHTML = "";
  }

  // Detailed advice
  const adviceSection = document.getElementById("advice-section");
  const areasToAdvise = weakAreas.length > 0 ? weakAreas : SECTIONS.map((s, si) => ({ title: s.title, si }));

  let adviceHtml = "";
  if (weakAreas.length > 0) {
    adviceHtml += `<h2 style="margin:1.25rem 0 0.75rem;font-size:15px;color:#0F172A">Your personalised recommendations</h2>`;
  }

  areasToAdvise.forEach(area => {
    const advice = SECTION_ADVICE[area.title];
    if (!advice) return;

    const isWebsiteSection = area.title === "Website and online presence";
    const useNoWebsite = isWebsiteSection && !hasWebsite;
    const content = isWebsiteSection
      ? (useNoWebsite ? advice.noWebsite : advice.hasWebsite)
      : advice;

    const stepsHtml = content.steps.map((step, i) =>
      `<li><div class="step-num">${i + 1}</div><span>${step}</span></li>`
    ).join("");

    // Determine if we show a Tulivo pill for this section
    const showTulivo = isWebsiteSection ? content.showTulivo : advice.showTulivo;
    const tulivoText = isWebsiteSection ? content.tulivo : advice.tulivo;

    // For social media: show a generic "get advice" pill instead
    const isSocial = area.title === "Social media";

    adviceHtml += `
      <div class="advice-card">
        <div class="advice-header" style="background:${advice.color};color:${advice.textColor}">
          <span>${advice.icon}</span>
          <span>${area.title}</span>
        </div>
        <div class="advice-body">
          <p>${content.intro}</p>
          <ul class="advice-steps">${stepsHtml}</ul>
          ${isSocial ? `
            <div class="info-pill">
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4.5" stroke="#166534" stroke-width="1"/><path d="M5 3v2.5M5 7v.5" stroke="#166534" stroke-width="1.2" stroke-linecap="round"/></svg>
              Want specific advice for your social media?
            </div>
            <p style="margin-top:8px;font-size:12px;color:#6B7280;font-style:italic">If you have questions about your social media strategy, content or platforms, get in touch and we are happy to point you in the right direction.</p>
          ` : showTulivo ? `
            <div class="tulivo-pill">
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4.5" stroke="#2563EB" stroke-width="1"/><path d="M5 3v2l1 1" stroke="#2563EB" stroke-width="1" stroke-linecap="round"/></svg>
              Tulivo Digital can help with this
            </div>
            <p style="margin-top:8px;font-size:12px;color:#6B7280;font-style:italic">${tulivoText}</p>
          ` : ''}
        </div>
      </div>`;
  });

  adviceSection.innerHTML = adviceHtml;

  // CTA — adapt based on situation
  const ctaArea = document.getElementById("cta-area");
  const hasWebsiteIssue = weakAreas.some(w => w.title === "Website and online presence");
  const hasContentIssue = weakAreas.some(w => w.title === "Search and content");
  const hasSalesIssue = weakAreas.some(w => w.title === "Lead capture and follow-up");

  let ctaTitle, ctaBody, ctaBtn;

  if (!hasWebsite) {
    ctaTitle = "Ready to get your business online properly?";
    ctaBody = "Tulivo Digital builds professional websites for small businesses — fast, clear and designed to convert visitors into real inquiries. Book a free consultation today. No obligation, no jargon, just honest advice.";
    ctaBtn = "Book a free website consultation";
  } else if (hasWebsiteIssue) {
    ctaTitle = "Your website needs attention — we can help.";
    ctaBody = "Tulivo Digital designs and builds websites for small businesses that are fast, clear and built to convert. We also write SEO content and set up automated lead follow-up so your site works hard for you 24 hours a day.";
    ctaBtn = "Book my free website review";
  } else if (hasContentIssue) {
    ctaTitle = "Let's get your business found on Google.";
    ctaBody = "Tulivo Digital optimises websites for search engines and writes SEO-focused blog content that brings in qualified traffic consistently — without paid ads. Book a free consultation and we will show you exactly where the opportunities are.";
    ctaBtn = "Book a free SEO consultation";
  } else if (hasSalesIssue) {
    ctaTitle = "Let's automate your lead follow-up.";
    ctaBody = "Tulivo Digital builds marketing funnels and automated lead response systems for small businesses — so every inquiry gets a fast, professional reply and a follow-up sequence that converts, whether you are at your desk or not.";
    ctaBtn = "Book a free consultation";
  } else {
    ctaTitle = "Your marketing foundations are strong — let's build on them.";
    ctaBody = "Book a free consultation with Tulivo Digital. We specialise in websites, SEO content, marketing funnels and automated lead systems for small businesses. We will identify the highest-impact next steps for your specific business.";
    ctaBtn = "Book a free consultation";
  }

  ctaArea.innerHTML = `<div class="cta-box">
    <h3>${ctaTitle}</h3>
    <p>${ctaBody}</p>
    <a href="https://tulivo.digital">${ctaBtn}</a>
  </div>`;

  show("s3");
  window.scrollTo({ top: 0, behavior: "smooth" });
}

function show(id) {
  document.querySelectorAll(".screen").forEach(s => s.classList.remove("active"));
  document.getElementById(id).classList.add("active");
}

function resetAll() {
  Object.keys(answers).forEach(k => delete answers[k]);
  totalAnswered = 0;
  hasWebsite = true;
  document.getElementById("fname").value = "";
  document.getElementById("bname").value = "";
  document.getElementById("email").value = "";
  document.getElementById("prog").style.width = "0%";
  document.getElementById("prog-count").textContent = "0";
  show("s1");
  window.scrollTo({ top: 0, behavior: "smooth" });
}
</script>

</body>
</html>
